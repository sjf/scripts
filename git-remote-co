#!/bin/bash
set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") <branch> [remote]" >&2
  echo "       $(basename "$0") <remote> <branch>" >&2
  echo >&2
  echo "Examples:" >&2
  echo "  $(basename "$0") sjf/compact-channel-tool-error-warnings" >&2
  echo "  $(basename "$0") origin sjf/compact-channel-tool-error-warnings" >&2
}

if [[ $# -lt 1 || $# -gt 2 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 2
fi

remote=origin
branch=$1

if [[ $# -eq 2 ]]; then
  if git remote get-url "$1" >/dev/null 2>&1; then
    remote=$1
    branch=$2
  else
    branch=$1
    remote=$2
  fi
fi

git rev-parse --is-inside-work-tree >/dev/null

if git show-ref --verify --quiet "refs/heads/$branch"; then
  git switch "$branch"
  exit 0
fi

if git remote get-url "$remote" >/dev/null 2>&1; then
  echo "Fetching $branch from $remote"
  git fetch "$remote" "+refs/heads/$branch:refs/remotes/$remote/$branch"
  git switch --create "$branch" "refs/remotes/$remote/$branch"

  if ! git branch --set-upstream-to="$remote/$branch" "$branch" 2>/dev/null; then
    git config "branch.$branch.remote" "$remote"
    git config "branch.$branch.merge" "refs/heads/$branch"
  fi
else
  echo "Fetching $branch from $remote"
  git fetch "$remote" "refs/heads/$branch"
  git switch --create "$branch" FETCH_HEAD
  echo "Checked out $branch from $remote; no upstream was configured because '$remote' is not a named remote."
fi
